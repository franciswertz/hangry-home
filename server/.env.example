# Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hangry?schema=public"

# AgentQ MQTT integration (local dev defaults)
JOB_QUEUE_PROVIDER=agentq
AGENTQ_APP_ID=hangry
AGENTQ_PROVIDER=openai
AGENTQ_MODEL=gpt-5.1-codex-mini
AGENTQ_TEMPERATURE=0.2
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_ENQUEUE_TOPIC=jobs/enqueue/{app_id}
MQTT_COMPLETE_TOPIC=jobs/complete/{app_id}
MQTT_QOS=1
STATUS_BASE_URL=http://localhost:8080

# Authlocal
AUTHLOCAL_URL=https://auth.local
AUTH_ISSUER=https://auth.local
AUTH_AUDIENCE=authlocal
AUTH_REQUIRED_ROLE=hangry-user
