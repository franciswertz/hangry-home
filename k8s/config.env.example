NODE_ENV=production
CORS_ORIGINS=["https://example.com"]
JOB_QUEUE_PROVIDER=agentq
AGENTQ_APP_ID=hangry-home
AGENTQ_PROVIDER=your-provider
AGENTQ_MODEL=your-model
MQTT_BROKER_URL=tcp://mqtt.example.com:1883
MQTT_ENQUEUE_TOPIC=jobs/enqueue/{app_id}
MQTT_COMPLETE_TOPIC=jobs/complete/{app_id}
MQTT_QOS=1

# Kustomize-only values
INGRESS_HOST=example.com
CLIENT_IMAGE=registry.example.com/hangry-home-client:latest
SERVER_IMAGE=registry.example.com/hangry-home-server:latest
